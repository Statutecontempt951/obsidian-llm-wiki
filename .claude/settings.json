{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__vault-mind.*",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/dogfood-hook.py posttool"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/dogfood-hook.py stop"
          }
        ]
      }
    ]
  }
}
